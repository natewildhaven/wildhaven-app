{
  "compilerOptions": {
    "target": "ES2022",
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "outDir": "dist",
    "rootDir": "src",
    "types": ["node"],
    "esModuleInterop": true,
    "skipLibCheck": true,
    "strict": false,
    "baseUrl": "../../",
    "paths": {
      "@workspace/db": ["lib/db/src/index.ts"],
      "@workspace/db/schema": ["lib/db/src/schema/index.ts"],
      "@workspace/api-zod": ["lib/api-zod/src/index.ts"]
    }
  },
  "include": ["src"]
}
